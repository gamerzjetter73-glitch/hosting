# ═══════════════════════════════════════════════════════
#  91 CLUB — Environment Configuration v13
#  COPY THIS FILE TO .env AND FILL IN ALL VALUES
# ═══════════════════════════════════════════════════════

# ── DATABASE ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/club91

# ── SERVER ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_64_CHARS_MIN

# ── ADMIN ────────────────────────────────────────────────
ADMIN_KEY=REPLACE_WITH_STRONG_ADMIN_KEY

# ── RAZORPAY (Deposits) ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── CASHFREE (Payouts / Withdrawals) ────────────────────
# Sign up: https://merchant.cashfree.com → API Keys
CASHFREE_APP_ID=REPLACE_WITH_CASHFREE_APP_ID
CASHFREE_SECRET_KEY=REPLACE_WITH_CASHFREE_SECRET_KEY
CASHFREE_MODE=PROD

# ── CORS ─────────────────────────────────────────────────
# Comma-separated, no trailing slash
ALLOWED_ORIGINS=https://legitclub.xyz,http://localhost:3000,http://localhost:5173

# ── GAME ────────────────────────────────────────────────
AUTO_RESULT=1

# ── BACKUP ───────────────────────────────────────────────
BACKUP_INTERVAL_MINUTES=60
BACKUP_DIR=./backups

# ── S3 OFFSITE BACKUP (optional) ─────────────────────────────────────────────
S3_BUCKET=your-backup-bucket-name
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com  # for Cloudflare R2/Backblaze B2

# ── EMAIL OTP (Gmail SMTP) ────────────────────────────────────────────────────
# Step 1: Enable 2-Factor Authentication on your Gmail account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail" → copy the 16-char password
# Step 4: Paste below (no spaces)
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=abcdefghijklmnop


# -- CRICKET LIVE AUTO-SYNC ---------------------------------------------------
# API: cricketdata.org (formerly CricAPI) -- host: api.cricapi.com
#
# Your key is on your cricketdata.org dashboard (e.g. bde2ff95-762a-4039-xxxx)
# It works at: https://api.cricapi.com/v1/currentMatches?apikey=YOUR_KEY&offset=0
#
# FREE plan  = 100 calls/day
#   Recommended interval: 900000 (poll every 15 min, uses ~96 calls/day)
#
# PAID plan  = Subscribe at cricketdata.org for higher limits
#   Recommended interval: 30000 (poll every 30 sec for ball-by-ball live bets)
#
CRICAPI_KEY=bde2ff95-762a-4039-YOUR_FULL_KEY_HERE
CRICKET_AUTO_SYNC=true
CRICKET_SYNC_INTERVAL=30000
# Free plan safe: 900000  |  Paid plan live: 30000
